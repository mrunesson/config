Include ~/.ssh/config.local

Host nuc01.local
    User magru
    HostName 192.168.108
	NoHostAuthenticationForLocalhost yes
	CheckHostIP no
    ControlPath ~/.ssh/sock/%r@%h:%p
    ControlMaster auto
    IdentityFile ~/.ssh/2021_id
    AddKeysToAgent yes
    UseKeychain yes

Host *.local
	NoHostAuthenticationForLocalhost yes
	CheckHostIP no

Host 192.168.122.?
	NoHostAuthenticationForLocalhost yes
	CheckHostIP no

Host *.ctrl-c.liu.se
    User runeson
    CheckHostIP yes
    IdentityFile ~/.ssh/id_rsa

Host node*
    User ubuntu
    CheckHostIp no

Host *
	ControlPath ~/.ssh/sock/%r@%h:%p
	ControlMaster auto
	NoHostAuthenticationForLocalhost yes
	IdentityFile ~/.ssh/2021_id
    AddKeysToAgent yes
    UseKeychain yes
